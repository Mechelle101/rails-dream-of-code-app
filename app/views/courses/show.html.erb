
<h1><%= @course.coding_class.title %></h1>
<p><strong>Trimester: </strong><%= "#{@course.trimester.term} - #{@course.trimester.year}" %></p>

<h2>Enrolled Students</h2>
<% if @students.any? %>
  <ul>
    <% @students.each do |s| %>
      <li><%= "#{s.first_name} #{s.last_name}" %></li>
      <% end %>
  </ul>
<% else %>
    <p>No enrolled students yet.</p>
<% end %>
